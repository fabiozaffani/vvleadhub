{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard", ":semanticCommits"],
  "timezone": "America/Sao_Paulo",
  "schedule": ["before 9am on monday"],
  "prConcurrentLimit": 5,
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Minor/patch agrupados quinzenais (09 §7)",
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "non-major deps",
      "schedule": ["every 2 weeks on monday"]
    },
    {
      "description": "Major isolado, com changelog para leitura humana (09 §7)",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "schedule": ["at any time"],
    "prPriority": 10
  },
  "lockFileMaintenance": { "enabled": true, "schedule": ["before 9am on monday"] }
}
