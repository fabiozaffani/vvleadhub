{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "D=$(git rev-parse --show-toplevel 2>/dev/null); H=\"${D%/*}/vvcore/bin/hook-wo-fence.sh\"; [ -n \"$D\" ] && [ -f \"$H\" ] && bash \"$H\" || true",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "D=$(git rev-parse --show-toplevel 2>/dev/null); H=\"${D%/*}/vvcore/bin/hook-secret-scan.sh\"; [ -n \"$D\" ] && [ -f \"$H\" ] && bash \"$H\" || true",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "D=$(git rev-parse --show-toplevel 2>/dev/null); H=\"${D%/*}/vvcore/bin/hook-prompt-governance.sh\"; [ -n \"$D\" ] && [ -f \"$H\" ] && bash \"$H\" || true",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "D=$(git rev-parse --show-toplevel 2>/dev/null); H=\"${D%/*}/vvcore/bin/hook-session-sync.sh\"; if [ -n \"$D\" ] && [ -f \"$H\" ]; then bash \"$H\"; else git pull --ff-only || echo \"[session] pull pulou: branch divergente - sincronize a mao\"; fi",
            "shell": "bash",
            "timeout": 30,
            "statusMessage": "Puxando ultimas mudancas do GitHub..."
          },
          {
            "type": "command",
            "shell": "bash",
            "command": "D=$(git rev-parse --show-toplevel 2>/dev/null) && V=\"$(dirname \"$D\")/vvcore\" && { if [ -d \"$V/.git\" ]; then git -C \"$V\" pull --ff-only || echo \"[vvcore] pull pulou (divergente/local) — sincronize o vvcore a mao\"; else git clone https://github.com/fabiozaffani/vvcore.git \"$V\"; fi; } && bash \"$V/bin/setup-links.sh\" || echo \"[vvcore] bootstrap pulou\"",
            "timeout": 120,
            "statusMessage": "Sincronizando vvcore (skills compartilhadas)..."
          }
        ]
      }
    ]
  }
}
