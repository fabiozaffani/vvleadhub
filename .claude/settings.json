{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "git pull --ff-only || echo \"[session] pull pulou: branch divergente ou alteracoes locais — sincronize a mao\"",
            "timeout": 30,
            "statusMessage": "Puxando ultimas mudancas do GitHub..."
          }
        ]
      }
    ]
  }
}
