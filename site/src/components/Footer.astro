---
// Footer global — NAP idêntico ao structured data (composicao-paginas §1).
// Conteúdo de NAP/redes = placeholders a confirmar (inventário 🔴 1.4).
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <p class="footer-brand">Vale Verde Festas</p>
      <p class="footer-nap">
        Endereço a confirmar<br />
        Telefone a confirmar
      </p>
      <p class="placeholder-note">NAP provisório — a confirmar com o inventário.</p>
    </div>
    <nav class="footer-col" aria-label="Institucional">
      <span class="footer-title">Institucional</span>
      <a href="/" class="vv-focus">O Espaço</a>
      <a href="/blog" class="vv-focus">Blog</a>
      <a href="#contato" class="vv-focus">Agende uma visita</a>
    </nav>
    <nav class="footer-col" aria-label="Legal e redes">
      <span class="footer-title">Legal</span>
      <a href="#" class="vv-focus">Política de privacidade</a>
      <a href="#" class="vv-focus">Termos de uso</a>
      <span class="footer-title" style="margin-top:1rem">Redes</span>
      <a href="#" class="vv-focus">Instagram</a>
    </nav>
  </div>
  <div class="container footer-base">
    <p>&copy; {new Date().getFullYear()} Vale Verde Festas. Todos os direitos reservados.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: linear-gradient(160deg, var(--green) 0%, var(--green-deep) 100%);
    color: var(--cream);
    padding-block: clamp(3rem, 7vw, 5rem) 2rem;
    margin-top: 2rem;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  .footer-brand {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.3rem;
    margin-bottom: 0.6rem;
  }
  .footer-nap {
    color: rgba(255, 251, 247, 0.85);
    margin-bottom: 0.4rem;
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .footer-col a {
    color: rgba(255, 251, 247, 0.9);
    text-decoration: none;
  }
  .footer-col a:hover {
    color: var(--gold);
  }
  .footer-title {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.72rem;
    color: var(--gold);
    margin-bottom: 0.2rem;
  }
  .site-footer .placeholder-note {
    color: rgba(255, 251, 247, 0.6);
  }
  .footer-base {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 251, 247, 0.16);
    font-size: 0.82rem;
    color: rgba(255, 251, 247, 0.7);
  }
  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }
</style>
