engine-strict=true
auto-install-peers=true
# Replit ship pnpm 10; o pin packageManager=pnpm@9.15.0 fazia o pnpm 10 tentar
# auto-trocar e travar num symlink (sem permissão). Desligado: usa o pnpm presente.
# CI continua determinístico via pnpm/action-setup (instala o 9.15.0 explicitamente).
manage-package-manager-versions=false
