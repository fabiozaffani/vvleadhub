# =============================================================================
# .env.example — inventário de secrets (docs/specs/engenharia/ambientes-secrets.md). NUNCA commitar .env real.
# Em produção/preview, os valores vivem no secret store do provedor de hospedagem / GitHub Actions secrets.
# Cada runtime lê só o que lhe pertence. Nomes EXATOS — não inventar variações.
# =============================================================================

# --- Banco (D-9: um Postgres, dois schemas) -----------------------------------
# Dois roles distintos (ver infra/db/roles.sql): cada um sem acesso ao schema do outro.
DATABASE_URL_APP=postgres://vvf_app:CHANGE_ME@localhost:5432/vvf?schema=app
DATABASE_URL_PAYLOAD=postgres://vvf_payload:CHANGE_ME@localhost:5432/vvf?schema=payload
# SSL da conexão Postgres: `require` liga TLS (Postgres gerenciado costuma exigir); vazio/
# ausente = desligado (Postgres local de dev sem SSL). Lido por admin/payload.config.ts.
DATABASE_SSL=

# --- admin (Payload) ----------------------------------------------------------
PAYLOAD_SECRET=
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# --- PostHog (D-3 / D-15) -----------------------------------------------------
# Analytics entra por proxy reverso no Cloudflare (D-15); estes alimentam SDK + cola fina.
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_API_KEY=

# --- Kommo (D-4 / D-6) --------------------------------------------------------
KOMMO_TOKEN=
KOMMO_WEBHOOK_SECRET=
KOMMO_BASE_URL=

# --- Plataformas de mídia (D-13/D-14 — server-side / loop fechado) ------------
META_CAPI_TOKEN=
META_PIXEL_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
TIKTOK_ACCESS_TOKEN=
TIKTOK_PIXEL_ID=
PINTEREST_ACCESS_TOKEN=

# --- Cloudflare (D-2 / D-10 — R2, Images, purge) ------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
CF_API_TOKEN=
CF_ZONE_ID=

# --- Auth serviço-a-serviço (D-12) --------------------------------------------
SERVICE_TOKEN_SECRET=

# --- Observabilidade (docs/specs/engenharia/observabilidade.md) ---------------
SENTRY_DSN_SITE=
SENTRY_DSN_ADMIN=
SENTRY_DSN_API=
