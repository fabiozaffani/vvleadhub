{
  "name": "vvleadhub",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "VVF — plataforma de geração de leads (monorepo). Conduta do agente: AGENTS.md.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=21"
  },
  "scripts": {
    "verify": "pnpm typecheck && pnpm lint && pnpm boundaries && pnpm test && pnpm build",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "boundaries": "depcruise --config .dependency-cruiser.cjs site admin api-server packages",
    "test": "pnpm -r --if-present test",
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --parallel --stream --filter @vvf/admin --filter @vvf/site dev",
    "db:up": "docker compose -f infra/db/docker-compose.dev.yml up -d",
    "db:down": "docker compose -f infra/db/docker-compose.dev.yml down",
    "db:reset": "docker compose -f infra/db/docker-compose.dev.yml down -v",
    "seed": "pnpm --filter @vvf/admin seed",
    "ship": "gh pr create --fill --base main && gh pr merge --auto --squash --delete-branch"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "@lhci/cli": "^0.15.1",
    "dependency-cruiser": "^16.8.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "playwright": "^1.60.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
